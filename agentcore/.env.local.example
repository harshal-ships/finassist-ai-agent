# AgentCore local dev secrets — copy to .env.local and fill in
AGENTDUET_API_KEY=
AGENTDUET_CONNECTOR_UUID=

# AWS: prefer SSO (do not commit keys). In your shell before dev/deploy:
#   export AWS_PROFILE=your-sso-profile
#   aws sso login --profile your-sso-profile

AWS_DEFAULT_REGION=ap-southeast-1
NOVA_SONIC_REGION=ap-northeast-1
NOVA_SONIC_MODEL_ID=amazon.nova-2-sonic-v1:0
NOVA_SONIC_VOICE_ID=matthew

# Call transcript logging (uploaded to S3 when each call ends)
TRANSCRIPT_S3_BUCKET=
TRANSCRIPT_S3_PREFIX=finassist/transcripts
